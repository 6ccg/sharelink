# ShareLink Server Configuration Template

PORT=8080
DB_TYPE=sqlite
DB_DSN=/data/sharelink.db
DATA_DIR=/data
IP_DB_PATH=/app/data/ip2region.xdb
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_TIMEZONE=Asia/Shanghai

# CRITICAL: Change this password on deployment. The server will not start if database is empty and this is unset.
INITIAL_ADMIN_PASSWORD=change-me-promptly

# JWT Secret Key - Change this to a secure random string of 32 characters in production.
JWT_SECRET=sharelink-session-secret-key-32-chars

# Frontend dev server only. Production builds use same-origin API requests.
VITE_API_BASE_URL=http://localhost:8080
